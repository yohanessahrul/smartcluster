NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SESSION_SECRET=replace-with-random-32-char-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Wajib sama persis dengan Authorized redirect URI di Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Opsional override base URL untuk build auth URL.
# GOOGLE_OAUTH_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_perumahan
# Optional: gunakan ini jika ingin eksplisit pakai koneksi PostgreSQL Supabase
# SUPABASE_DB_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=payment-proofs
# Jika pakai Supabase PostgreSQL, biarkan DB_SSL kosong atau set true
DB_SSL=false

# Seed superadmin default (otomatis dipastikan ada saat backend ready)
DEFAULT_SUPERADMIN_EMAIL=yohanessahrul92@gmail.com
DEFAULT_SUPERADMIN_NAME=Yohanes Sahrul
DEFAULT_SUPERADMIN_PHONE=081703631403
